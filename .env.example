# =============================================================================
# Volenti — Environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every variable here is parsed and validated by Zod at startup
# (see apps/web/src/lib/validation/env.ts). A missing/invalid value fails fast
# instead of producing fake behaviour.
# =============================================================================

# --- Core ---------------------------------------------------------------------
# Node runtime mode: development | test | production
NODE_ENV=development

# --- Database (PostgreSQL 16) -------------------------------------------------
# Full connection string. Matches docker-compose.yml for local development.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# --- Auth (better-auth, self-hosted) ------------------------------------------
# Secret used to sign sessions/tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL better-auth issues callbacks/cookies for.
BETTER_AUTH_URL=http://localhost:3000

# --- AI: Text (Anthropic API) -------------------------------------------------
# Server-side only. Used for the Intent Router (Haiku) and text generation (Sonnet).
ANTHROPIC_API_KEY=

# --- AI: Image (fal.ai / FLUX) ------------------------------------------------
# Server-side only. Used by the image generation job worker (via server proxy).
FAL_API_KEY=

# --- Billing (Stripe) ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Public app config (exposed to the browser) -------------------------------
# Must be prefixed NEXT_PUBLIC_ to be available client-side.
NEXT_PUBLIC_APP_URL=http://localhost:3000
